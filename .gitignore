# --- Quarto build artefacts ---------------------------------------
/.quarto/
/_site/
**/*.quarto_ipynb
**/*_cache/

# --- OS junk ------------------------------------------------------
.DS_Store
Thumbs.db

# --- Local-only planning -----------------------------------------
# Planning catalogs, status notes, and any review bundles. These are
# never part of the public course site.
/_site_planning/

# --- Private assessment machinery ---------------------------------
# These directories live in the *private* teaching workspace
# (D:/My Drive School/Teaching/courses/math-software/). If they ever
# reappear in this public repo, treat that as a mistake and remove
# them before committing.
/bank/
/builder/
/_source_material/
/private/
/private_assessments/
/keys/
/answer_keys/
/exams/
/quizzes/

# --- Filename patterns for stray private artifacts ----------------
# Answer keys, secure exam variants, raw R data dumps.
*_key.*
*_key_*.*
*answer_key*
*.RData
*.rds

# --- Local-only editor / IDE / R droppings ------------------------
.Rhistory
.Rproj.user/
.vscode/
